@echo off
chcp 65001 >nul
echo ========================================
echo 重命名旧目录为备份
echo ========================================
echo.
echo 这将会:
echo 1. 关闭可能占用文件的程序
echo 2. 将 "实验报告 1" 重命名为 "实验报告 1_备份_20260301"
echo 3. 以后只在 "D:\Trae CN\论文" 工作
echo.
echo ========================================
echo.

echo 正在重命名目录...
echo.
echo 旧目录：D:\Trae CN\实验报告 1
echo 新目录：D:\Trae CN\实验报告 1_备份_20260301
echo.

ren "D:\Trae CN\实验报告 1" "实验报告 1_备份_20260301"

if %errorlevel%==0 (
    echo ========================================
    echo ✓ 重命名成功！
    echo ========================================
    echo.
    echo 从现在开始:
    echo ✓ 工作目录：D:\Trae CN\论文\
    echo ✓ 备份目录：D:\Trae CN\实验报告 1_备份_20260301\
    echo.
    echo 您不需要再使用备份目录，它只是作为历史存档。
    echo.
) else (
    echo ========================================
    echo ✗ 重命名失败
    echo ========================================
    echo.
    echo 可能原因:
    echo 1. 有文件正在被使用
    echo 2. 目录已被重命名
    echo.
    echo 请关闭所有可能使用该目录的程序:
    echo - 文件资源管理器窗口
    echo - IDE (Trae)
    echo - 命令行窗口
    echo.
    echo 然后重新运行此脚本。
    echo.
)

pause
